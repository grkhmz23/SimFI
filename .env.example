# ============================================================================
# SimFi Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================================

# ----------------------------------------------------------------------------
# REQUIRED - Core Application
# ----------------------------------------------------------------------------

# Database connection (PostgreSQL)
# Example: postgresql://user:password@host:port/database
DATABASE_URL=

# JWT secret for authentication (generate a strong random string)
# Minimum 32 characters recommended
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Session secret (can be same as JWT_SECRET)
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# Node environment
NODE_ENV=production

# ----------------------------------------------------------------------------
# TELEGRAM BOT (Optional - only if running bot)
# ----------------------------------------------------------------------------

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# Development bot token (optional, for local testing)
TELEGRAM_BOT_TOKEN_DEV=

# Secret for bot-to-backend API communication
# Must be at least 20 characters in production
BOT_API_SECRET=simfi-dev-bot-secret-change-in-production

# API base URL for bot to communicate with backend
# In production: https://your-app.onrender.com
# In development: http://localhost:5000
API_BASE_URL=http://localhost:5000

# Auto-start bot with web server (development only)
# Set to 'true' to auto-start, 'false' to run separately
AUTO_START_BOT=false

# ----------------------------------------------------------------------------
# REWARDS ENGINE (Optional - for real SOL prizes)
# ----------------------------------------------------------------------------

# Solana RPC URL (Helius, QuickNode, etc.)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Rewards vault private key (base58 encoded)
# This wallet must have SOL for gas and holds creator fees
REWARDS_VAULT_PRIVATE_KEY=

# Token mint for claiming fees (your token's mint address)
REWARDS_TOKEN_MINT=

# Bags API key for fee claiming
BAGS_API_KEY=

# Rewards pool percentage (in basis points)
# 5000 = 50% of fees go to rewards, 50% to treasury
REWARDS_POOL_BPS=5000

# Minimum trades required to qualify for rewards
REWARDS_MIN_TRADES=3

# Reserve amount in vault (lamports) - 0.05 SOL default
VAULT_RESERVE_LAMPORTS=50000000

# Dry run mode for testing (set to "true" to simulate without real transactions)
REWARDS_DRY_RUN=false

# ----------------------------------------------------------------------------
# OPTIONAL - Enhanced Features
# ----------------------------------------------------------------------------

# Redis URL for shared rate limiting (multi-instance deployments)
# Example: redis://user:password@host:port
REDIS_URL=

# Helius API key for enhanced token analysis
HELIUS_API_KEY=

# Birdeye API key (optional, free tier works for basic features)
BIRDEYE_API_KEY=

# ----------------------------------------------------------------------------
# DEVELOPMENT ONLY
# ----------------------------------------------------------------------------

# Port for local development
PORT=5000
