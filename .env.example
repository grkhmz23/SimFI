# ============================================================================
# SimFi Environment Configuration
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit live API keys to this file or any tracked file.
#            Rotate any key that was previously committed to version control.
# ============================================================================

# ----------------------------------------------------------------------------
# REQUIRED - Core Application
# ----------------------------------------------------------------------------

# Database connection (PostgreSQL)
# Example: postgresql://user:password@host:port/database
DATABASE_URL=

# JWT secret for authentication (generate a strong random string, min 32 chars)
# Generate: openssl rand -hex 32
JWT_SECRET=replace-with-a-strong-random-secret-min-32-chars

# Session secret (can be same as JWT_SECRET)
# Generate: openssl rand -hex 32
SESSION_SECRET=replace-with-a-strong-random-secret-min-32-chars

# Node environment
NODE_ENV=production

# Frontend URL — required for CORS in production
# Example: https://your-app.onrender.com or https://simfi.fun
FRONTEND_URL=https://your-production-domain.com

# ----------------------------------------------------------------------------
# BASE CHAIN (Ethereum L2)
# ----------------------------------------------------------------------------

# Base RPC URL (Alchemy, Infura, or public Base RPC)
# Get from: https://www.alchemy.com/ or https://www.infura.io/
# Public fallback: https://mainnet.base.org
BASE_RPC_URL=https://mainnet.base.org

# Base chain ID (8453 for mainnet, 84532 for testnet)
BASE_CHAIN_ID=8453

# BaseScan API key for contract verification and token info
# Get from: https://basescan.org/apis
BASESCAN_API_KEY=

# ----------------------------------------------------------------------------
# SOLANA CHAIN
# ----------------------------------------------------------------------------

# Solana RPC URL (Helius, QuickNode, etc.)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Helius API key for enhanced Solana features
# Get from: https://helius.dev
HELIUS_API_KEY=your-helius-api-key-here

# ----------------------------------------------------------------------------
# TELEGRAM BOT (Optional - only if running bot)
# ----------------------------------------------------------------------------

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# Development bot token (optional, for local testing)
TELEGRAM_BOT_TOKEN_DEV=

# Secret for bot-to-backend API communication
# Must be at least 20 characters in production
BOT_API_SECRET=replace-with-strong-random-bot-secret-min-20-chars

# API base URL for bot to communicate with backend
# In production: https://your-app.onrender.com
# In development: http://localhost:5000
API_BASE_URL=https://your-production-domain.com/api

# Public URL for webhook (must match your deployment domain)
# In production: https://your-app.onrender.com
PUBLIC_URL=https://your-production-domain.com

# Webhook secret path — Telegram sends updates to /telegram/webhook/<secret>
# Generate a strong random string, keep it secret
TELEGRAM_WEBHOOK_SECRET_PATH=your-random-webhook-secret-path

# Webhook secret token — Telegram includes this in X-Telegram-Bot-Api-Secret-Token header
# Must be at least 20 characters in production
TELEGRAM_WEBHOOK_SECRET_TOKEN=your-random-webhook-secret-token

# Auto-start bot with web server (development only)
# Set to 'true' to auto-start, 'false' to run separately
AUTO_START_BOT=false

# ----------------------------------------------------------------------------
# ALPHA DESK (AI-curated daily token ideas)
# ----------------------------------------------------------------------------

# Primary LLM provider: Moonshot
MOONSHOT_API_KEY=your-moonshot-api-key-here
MOONSHOT_MODEL=kimi-k2-thinking-turbo
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1/chat/completions

# Fallback LLM provider: OpenAI
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions

# Fallback LLM provider: OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions

# Twitter/X signal ingestion via SocialData.tools
SOCIALDATA_API_KEY=your-socialdata-api-key-here

# GitHub dev-signal ingestion (optional)
GITHUB_TOKEN=

# Admin token for triggering pipeline runs (min 20 chars)
# Generate: openssl rand -hex 24
ADMIN_TOKEN=replace-with-strong-random-admin-token-min-20-chars

# Max pipeline runs per chain per day (cost guard)
ALPHA_DESK_MAX_RUNS_PER_DAY=2

# LLM provider failover order (comma-separated)
LLM_PROVIDER_ORDER=moonshot,openai,openrouter

# ----------------------------------------------------------------------------
# OPTIONAL - Enhanced Features
# ----------------------------------------------------------------------------

# Redis URL for shared rate limiting (multi-instance deployments)
# Example: redis://user:password@host:port
REDIS_URL=

# Birdeye API key for token metadata (optional, free tier works)
# Get from: https://bds.birdeye.so
BIRDEYE_API_KEY=your-birdeye-api-key-here

# Jupiter API key for Solana swap quotes and token data
# Get from: https://developers.jup.ag/portal
JUPITER_API_KEY=your-jupiter-api-key-here

# CoinGecko API key (optional, free tier has rate limits)
COINGECKO_API_KEY=

# ----------------------------------------------------------------------------
# DEVELOPMENT ONLY
# ----------------------------------------------------------------------------

# Port for local development
PORT=5000

# ----------------------------------------------------------------------------
# PREDICTION MARKETS (Polymarket paper trading)
# ----------------------------------------------------------------------------

# Polymarket public endpoints (no auth required)
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# Paper trading defaults
PREDICTION_STARTING_BALANCE_USD=10000

# Settler cadence
PREDICTION_SETTLE_INTERVAL_SECONDS=60

# Optional: cap on WS subscription set
PREDICTION_WS_MAX_SUBSCRIPTIONS=200

# ----------------------------------------------------------------------------
# SPORTSBOOK (Paper sports betting)
# ----------------------------------------------------------------------------

# Primary odds provider: "odds-api-io" | "the-odds-api"
ODDS_PROVIDER_PRIMARY=odds-api-io

# Odds-API.io — https://odds-api.io (free tier: 100 req/hour, no card)
ODDS_API_IO_KEY=your-odds-api-io-key-here
ODDS_API_IO_BASE_URL=https://api.odds-api.io/v3

# The Odds API — https://the-odds-api.com (free tier: 500 credits/month, no card)
THE_ODDS_API_KEY=your-the-odds-api-key-here
THE_ODDS_API_BASE_URL=https://api.the-odds-api.com/v4

# Active leagues (comma-separated The Odds API sport keys)
SPORTSBOOK_LEAGUES=basketball_nba,americanfootball_nfl,soccer_epl,soccer_uefa_champs_league

# Lazy refresh config
SPORTSBOOK_ODDS_TICK_SEC=60
SPORTSBOOK_ODDS_LAZY_WINDOW_SEC=600
SPORTSBOOK_ODDS_MIN_INTERVAL_SEC=300
SPORTSBOOK_SCORES_TICK_SEC=60
SPORTSBOOK_SCORES_ACTIVE_BEFORE_SEC=21600
SPORTSBOOK_SCORES_ACTIVE_AFTER_SEC=14400

# Settlement config
SPORTSBOOK_BET_VOID_AFTER_HOURS=168
