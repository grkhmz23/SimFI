# =============================================================================
# SimFi Rewards Engine Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: Bags SDK + Solana
# -----------------------------------------------------------------------------

# Bags.fm API key (get from https://dev.bags.fm)
BAGS_API_KEY=

# Solana RPC URL (recommend Helius for reliability)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Vault wallet private key (base58 encoded)
# This wallet receives claimed fees and pays out rewards
# SECURITY: Generate a dedicated wallet, never commit this
REWARDS_VAULT_PRIVATE_KEY=

# Token mint address to filter claimable positions
# This is your SimFi token launched on Bags.fm
REWARDS_TOKEN_MINT=

# -----------------------------------------------------------------------------
# ECONOMICS
# -----------------------------------------------------------------------------

# What percentage of claimed fees goes to rewards pool (basis points)
# 5000 = 50% to rewards, 50% stays as treasury
# 10000 = 100% to rewards
REWARDS_POOL_BPS=5000

# Minimum closed trades to be eligible for rewards
REWARDS_MIN_TRADES=3

# Reserve SOL to keep in vault for transaction fees (lamports)
VAULT_RESERVE_LAMPORTS=50000000

# -----------------------------------------------------------------------------
# ADMIN
# -----------------------------------------------------------------------------

# Secret for manual trigger endpoint (POST /api/rewards/run)
# Header: x-admin-secret or x-rewards-secret
REWARDS_ADMIN_SECRET=

# Alternative: use existing ADMIN_SECRET
# ADMIN_SECRET=

# -----------------------------------------------------------------------------
# TESTING
# -----------------------------------------------------------------------------

# Dry run mode: run all logic but skip actual claims/payouts
# Set to "1" to enable
REWARDS_DRY_RUN=0
